{
  "name": "halowiki",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate:images": "tsx scripts/generate-missing-images.ts",
    "generate:weapon": "GEN_TYPE=weapon tsx scripts/generate-type.ts",
    "generate:vehicle": "GEN_TYPE=vehicle tsx scripts/generate-type.ts",
    "generate:character": "GEN_TYPE=character tsx scripts/generate-type.ts",
    "generate:race": "GEN_TYPE=race tsx scripts/generate-type.ts",
    "generate:planet": "GEN_TYPE=planet tsx scripts/generate-type.ts",
    "generate:merge": "tsx scripts/merge-generated-images.ts",
    "generate:all": "FORCE_ALL=true tsx scripts/generate-type.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync:entities": "npx tsx scripts/sync-entities.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "framer-motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "google-auth-library": "^9.15.1",
    "tsx": "^4.21.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.0"
  }
}
