# Halopedia MediaWiki API
VITE_HALOPEDIA_API_URL=https://www.halopedia.org/api.php

# App metadata
VITE_APP_TITLE=Halo Wiki

# GCP Configuration (used in CI/CD only — do not set in frontend)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_ARTIFACT_REGISTRY=us-central1-docker.pkg.dev
CLOUD_RUN_SERVICE=halowiki
CLOUD_RUN_MIN_INSTANCES=0
CLOUD_RUN_MAX_INSTANCES=10
