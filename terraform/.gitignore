# Local variable values (contain project IDs, never commit)
terraform.tfvars
*.tfvars
!*.tfvars.example

# Terraform state (use remote backend in GCS for shared use)
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
